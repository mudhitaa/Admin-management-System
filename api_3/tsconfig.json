{
  "compilerOptions": {
    "rootDir": "./src",
    "outDir": "./dist",

    "module": "NodeNext",
    "moduleResolution": "NodeNext",

    "target": "ES2020",
    "types": ["node"],
    "lib": ["ES2020"],

    "strict": true,
    "esModuleInterop": true,
    "allowJs": true,
    "isolatedModules": true,
    "skipLibCheck": true,
    "pretty": true,
    "sourceMap": true,
    "resolveJsonModule": true,
    "forceConsistentCasingInFileNames": true,

    "typeRoots": ["./node_modules/@types", "./src/types"]
  }
}